# AI Trajectory Index — Environment Variables
# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# OpenRouter API Key
# Get your free key at https://openrouter.ai
# Used for AI country narratives and map chat (Gemini 2.0 Flash free tier)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Site URL — used for canonical URLs and Open Graph meta tags
NEXT_PUBLIC_SITE_URL=https://ai-trajectory-index.vercel.app

# Cron Secret — protects the /api/news-cron endpoint from unauthorised calls
# Set this in your Vercel environment variables and Vercel will send it automatically
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# Optional: override the default AI model (default shown below, free tier)
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
